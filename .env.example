DRIVER=~fastapi+~httpx+~websockets

# NoneBot 主监听地址。
# 常规 OneBot V11 部署直接连这个端口即可。
HOST=0.0.0.0
PORT=37564

# Core / Gateway 双进程模式专用端口。
# 默认单进程启动时不需要额外修改。
TAIKO_CORE_HOST=127.0.0.1
TAIKO_CORE_PORT=37563
TAIKO_GATEWAY_HOST=0.0.0.0
TAIKO_GATEWAY_PORT=37564

# 本地维护接口的独立地址。
# 默认情况下本地数据 API 已合并进 bot 进程，挂载在 /local-api。
# 只有你需要单独启动 taiko_data_api:app 时，才需要使用下面这些配置。
TAIKO_LOCAL_DATA_API_HOST=127.0.0.1
TAIKO_LOCAL_DATA_API_PORT=37565
TAIKO_LOCAL_DATA_API_BASE_URL=http://127.0.0.1:37565

# viewer 侧公共数据与中心代理接口。
TAIKO_PUBLIC_DATA_BASE_URL=https://viewer.sakura-bot.cn/api/taiko
TAIKO_VIEWER_BASE_URL=https://viewer.sakura-bot.cn

# viewer 开发者 token。
# 不填时仍可使用 viewer 的查询、更新、Hiroba、Wahlap 等中心代理接口，
# 但按匿名额度计数，默认每天 100 次。
# 填写后会带上 Authorization: Bearer <token>，
# 默认每天可调用 2500 次。
TAIKO_VIEWER_DEVELOPER_TOKEN=

# QQ 官方机器人发送 Markdown 图片时使用的公开图片基址。
# 如果你自建 viewer 域名，需要确保这个地址能直接访问 bot 输出的缓存图片。
QQ_MARKDOWN_IMAGE_BASE_URL=https://viewer.sakura-bot.cn/qqbot-cache/taiko

# QQ 官方机器人配置。
# 仅在你需要接入 QQ 频道/群/私聊官方机器人时填写。
# QQ_IS_SANDBOX=true 表示走沙箱环境。
QQ_IS_SANDBOX=false
# QQ_BOTS 是 JSON 数组，每个元素对应一个 QQ 官方机器人应用。
# 常见字段：
# - id: 机器人 AppID
# - token / secret: 官方后台分配的凭据
# - use_websocket: 是否启用 QQ 官方 WebSocket
# - intent: 事件订阅开关
# QQ_BOTS=[{"id":"your_app_id","token":"your_token","secret":"your_secret","use_websocket":true,"intent":{"c2c_group_at_messages":true,"at_messages":false}}]

# 功能白名单文件路径。
# 仅在你希望限制 bot 只在部分群启用时填写。
# 文件内容为 JSON 对象，例如：{"123456789":["987654321","1122334455"]}
# BOT_GROUP_WHITELIST_PATH=./storage/config/bot_group_whitelist.json
